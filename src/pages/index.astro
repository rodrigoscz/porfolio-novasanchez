---
import "../styles/theme.css";

const profile = {
  name: "Rodrigo Sánchez",
  displayName: "Rodrigo",
  handle: "@rodrigoscz_",
  role: "Dev y SEO tecnico",
  thesis: "Todo es lenguaje.",
  intro:
    "El codigo, el SEO, los reportes, los menus, los datos y las respuestas de un LLM. " +
    "Soy Rodrigo, dev y SEO tecnico desde el NEA. Construyo webapps e investigaciones para entender como las maquinas y las personas interpretan lo que publicamos.",
};

// Las herramientas de la suite. href apunta al subdominio planeado;
// repo queda como fallback verificable hasta que los subdominios esten cableados.
const suite = [
  {
    name: "tres-lenguas",
    tagline: "Un audit web, tres lentes.",
    desc: "Traduce un informe SEO o tecnico a las voces de Tecnico, CMO y CFO. Cliente puro, sin backend.",
    href: "https://tres-lenguas.novasanchez.com",
    repo: "https://github.com/rodrigoscz/tres-lenguas",
  },
  {
    name: "tropicaliza",
    tagline: "El espanol no es uno solo.",
    desc: "Linter de locale: marca rioplatensismos, calcos y registros que no viajan entre variantes del espanol.",
    href: "https://tropicaliza.novasanchez.com",
    repo: "https://github.com/rodrigoscz/tropicaliza",
  },
  {
    name: "nav-sense",
    tagline: "La navegacion tambien comunica.",
    desc: "Analiza la arquitectura de informacion de un sitio y senala donde el menu confunde en vez de guiar.",
    href: "https://nav-sense.novasanchez.com",
    repo: "https://github.com/rodrigoscz/nav-sense",
  },
  {
    name: "lang-forge",
    tagline: "El laboratorio de la suite.",
    desc: "Banco de experimentos e investigacion donde maduran las ideas que despues se vuelven herramientas.",
    href: "https://lab.novasanchez.com",
    repo: "https://github.com/rodrigoscz/lang-forge",
  },
];
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/nova-mark.svg" />
    <title>{profile.name} · {profile.thesis}</title>
    <meta
      name="description"
      content="Portfolio de Rodrigo Sanchez (rodrigoscz). Casa de la suite open-source todo es lenguaje."
    />
  </head>
  <body>
    <div class="site-actions" aria-label="Navegacion principal">
      <nav class="topnav">
        <a href="#sobre-mi">sobre mi</a>
        <a href="#suite">la suite</a>
        <a href="#contacto">contacto</a>
      </nav>
    </div>

    <main>
      <header class="hero">
        <span class="hero-mark">
          <img
            src="/nova-mark.svg"
            width="120"
            height="120"
            alt="Marca de Nova"
          />
        </span>
        <p class="thesis">{profile.thesis}</p>
        <p class="sub">
          {profile.intro}
          <a href="https://x.com/rodrigoscz_">{profile.handle}</a>
        </p>
      </header>

      <section id="sobre-mi">
        <h2>&gt; sobre mi</h2>
        <p>
          Me interesa la parte invisible del trabajo digital: como una auditoria
          se convierte en una decision, como una estructura semantica guia a un
          algoritmo, como un reporte deja de ser ruido y empieza a decir algo
          util.
        </p>
        <p>
          Durante anos el marketing digital lleno carpetas de reportes que
          alguien tenia que traducir para que un CMO o un CEO pudiera decidir
          algo. Hoy el problema es mas grande: tambien tenemos que ser
          entendidos por modelos, buscadores y sistemas que interpretan senales.
        </p>
        <p>
          Ahi esta mi lugar: convertir ruido tecnico en sentido. Con webapps,
          datasets, investigacion y codigo abierto.
        </p>
        <ul class="stack">
          <li>Python · SQL · DataForSEO</li>
          <li>TypeScript · Astro · Vite</li>
          <li>Ingenieria de LLMs · SEO tecnico · semantica</li>
        </ul>
      </section>

      <section id="suite">
        <h2>&gt; la suite «todo es lenguaje»</h2>
        <p class="section-intro">
          Herramientas open-source, 100% del lado del cliente, que tratan el
          lenguaje como materia prima. Cada una resuelve un problema concreto.
        </p>
        <div class="cards">
          {
            suite.map((tool) => (
              <article class="card">
                <h3>
                  <a href={tool.href}>{tool.name}</a>
                </h3>
                <p class="card-tagline">{tool.tagline}</p>
                <p class="card-desc">{tool.desc}</p>
                <p class="card-links">
                  <a href={tool.href}>abrir →</a>
                  <a href={tool.repo}>codigo</a>
                </p>
              </article>
            ))
          }
        </div>
        <p class="suite-hub">
          Indice completo de la suite en
          <a href="https://github.com/rodrigoscz/lang-suite">lang-suite</a>.
        </p>
      </section>

      <section id="contacto">
        <h2>&gt; contacto</h2>
        <p>
          Si trabajas en SEO, desarrollo o lenguaje aplicado a LLMs, conversemos.
        </p>
        <p class="contact-links">
          <a href="https://github.com/rodrigoscz">github</a>
          <a href="https://x.com/rodrigoscz_">{profile.handle}</a>
          <a href="mailto:rodrigoscz.dev@gmail.com">mail</a>
        </p>
      </section>

      <footer>
        <p class="suite">
          <img src="/nova-mark.svg" width="16" height="16" alt="" />
          {profile.name} · casa de la suite «todo es lenguaje» ·
          <a href="https://x.com/rodrigoscz_">{profile.handle}</a> ·
          <a href="https://github.com/rodrigoscz">github</a>
        </p>
      </footer>
    </main>

    <style is:global>
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        background: var(--arena);
        color: var(--ink);
        font-family: ui-monospace, "SF Mono", "JetBrains Mono", Menlo, monospace;
        line-height: 1.55;
      }
      p {
        text-align: justify;
      }
      main {
        max-width: 820px;
        margin: 0 auto;
        padding: 4.5rem 1.25rem 4rem;
      }
      .site-actions {
        position: fixed;
        top: 0.9rem;
        right: 0.9rem;
        z-index: 10;
        display: flex;
        align-items: center;
        gap: 1rem;
        background: color-mix(in srgb, var(--arena) 88%, transparent);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: 0.35rem;
        backdrop-filter: blur(10px);
      }
      .hero {
        text-align: center;
        padding: 1rem 0 1.5rem;
      }
      .hero-mark {
        display: inline-block;
      }
      .hero img {
        display: block;
        image-rendering: pixelated;
      }
      h1 {
        font-size: 2.4rem;
        margin: 0.4rem 0 0;
        letter-spacing: 0.04em;
      }
      .thesis {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--terra);
        margin: 0.6rem 0 0.3rem;
      }
      .sub {
        color: var(--brown);
        max-width: 58ch;
        margin: 0.6rem auto 0;
        text-align-last: center;
      }
      .hero a {
        color: var(--terra);
        text-decoration: none;
        border-bottom: 1px solid transparent;
      }
      .hero a:hover {
        border-bottom-color: var(--terra);
      }
      .topnav {
        display: flex;
        gap: 0.85rem;
        justify-content: center;
        flex-wrap: wrap;
      }
      .topnav a {
        color: var(--brown);
        text-decoration: none;
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        border-bottom: 1px solid transparent;
      }
      .topnav a:hover {
        color: var(--terra);
        border-bottom-color: var(--terra);
      }
      h2 {
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--brown);
        border-bottom: 2px solid var(--line);
        padding-bottom: 0.3rem;
        margin: 2.6rem 0 1rem;
      }
      section p {
        max-width: 64ch;
      }
      .section-intro {
        color: var(--brown);
      }
      .stack {
        list-style: none;
        padding: 0;
        margin: 1.8rem 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .stack li {
        font-size: 0.8rem;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 0.3rem 0.7rem;
        color: var(--brown);
      }
      .cards {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 0.5rem;
      }
      .card {
        background: var(--paper);
        border: 2px solid var(--line);
        border-radius: 10px;
        padding: 1rem 1.1rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
      }
      .card:hover {
        border-color: var(--terra);
      }
      .card h3 {
        margin: 0;
        font-size: 1.05rem;
        letter-spacing: 0.02em;
      }
      .card h3 a {
        color: var(--ink);
        text-decoration: none;
      }
      .card h3 a:hover {
        color: var(--terra);
      }
      .card-tagline {
        margin: 0;
        color: var(--terra);
        font-weight: 700;
        font-size: 0.85rem;
      }
      .card-desc {
        margin: 0;
        color: var(--brown);
        font-size: 0.85rem;
      }
      .card-links {
        margin: 0.4rem 0 0;
        display: flex;
        gap: 0.9rem;
        font-size: 0.82rem;
      }
      .card-links a {
        color: var(--terra);
        text-decoration: none;
        border-bottom: 1px solid transparent;
      }
      .card-links a:hover {
        border-bottom-color: var(--terra);
      }
      .suite-hub {
        margin-top: 1.2rem;
        font-size: 0.85rem;
        color: var(--brown);
      }
      .suite-hub a,
      #contacto a,
      footer a {
        color: var(--terra);
        text-decoration: none;
        border-bottom: 1px solid transparent;
      }
      .suite-hub a:hover,
      #contacto a:hover,
      footer a:hover {
        border-bottom-color: var(--terra);
      }
      .contact-links {
        display: flex;
        gap: 1.2rem;
        flex-wrap: wrap;
        margin-top: 0.6rem;
      }
      strong {
        color: var(--ink);
      }
      footer {
        margin-top: 3.5rem;
        font-size: 0.78rem;
        color: var(--brown);
        text-align: center;
      }
      .suite {
        opacity: 0.95;
      }
      .suite img {
        vertical-align: -3px;
        margin-right: 0.35rem;
        image-rendering: pixelated;
      }
      @media (prefers-reduced-motion: reduce) {
        * {
          animation: none !important;
        }
      }
      @media (max-width: 640px) {
        main {
          padding-top: 7rem;
        }
        .site-actions {
          left: 0.75rem;
          right: 0.75rem;
          justify-content: space-between;
        }
        .topnav {
          gap: 0.65rem;
        }
        .topnav a {
          font-size: 0.75rem;
        }
        .sub {
          text-align-last: left;
        }
        .cards {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
